# PostgreSQL数据库连接（必须设置）
DATABASE_URL=host=localhost user=postgres password=<your_password> dbname=zhix port=5432 sslmode=require TimeZone=Asia/Shanghai

# Redis配置
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# JWT密钥（必须设置，至少32位随机字符串）
JWT_SECRET=<generate_with: openssl rand -hex 32>

# CORS允许的前端域名
ALLOWED_ORIGIN=https://zhix.club

# 运行模式
GIN_MODE=release

# 服务器端口
PORT=8080
